# .streamlit/secrets.toml.example
#
# This is a template file. To use it:
# 1. Copy this file to secrets.toml in the same directory
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit secrets.toml to version control
#
# For Streamlit Cloud deployments, configure secrets through the
# Streamlit Cloud dashboard instead of using this file.

# Environment setting: "test" or "production"
ENV = "test"

# LLM provider and model
# MODEL is used for openai, deepinfra, and anthropic.
# When API_PROVIDER = "openrouter", MODEL is ignored for interview chat requests.
# OpenRouter uses Qwen by default and GPT-5.4 for industry_org_survey.
API_PROVIDER = "openai"  # openai | deepinfra | openrouter | anthropic
MODEL = "gpt-4o-mini"

# Provider credentials
API_KEY = "your-openai-api-key-here"
# ANTHROPIC_API_KEY = "your-anthropic-api-key-here"
# DEEPINFRA_API_KEY = "your-deepinfra-api-key-here"
# OPENROUTER_API_KEY = "your-openrouter-api-key-here"

# Optional: OpenRouter model routing
# OPENROUTER_DEFAULT_MODEL is the baseline for midterm, reflection, and other
# non-industry interviews. OPENROUTER_INDUSTRY_MODEL is used only for
# industry_org_survey.
# OPENROUTER_SITE_URL = "http://localhost:8501"
# OPENROUTER_APP_NAME = "SBI Midterm Interview"
# OPENROUTER_DEFAULT_MODEL = "qwen/qwen3.5-35b-a3b"
# OPENROUTER_INDUSTRY_MODEL = "openai/gpt-5.4"
# OPENROUTER_INDUSTRY_REASONING_EFFORT = "minimal"
# OPENROUTER_REASONING_MAX_TOKENS = 1536

# Optional: TTS settings for speech output (DeepInfra)
TTS_MODEL = "hexgrad/Kokoro-82M"
TTS_VOICE = "af_heart"

# Optional: Email configuration
# USE_LIACS_EMAIL = false
# EMAIL_PASSWORD = "your-gmail-app-password-here"

# Optional: LIACS SSH configuration for remote email/database access
# LIACS_SSH_USERNAME = "your-liacs-username"
# LIACS_SSH_KEY = "-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"

# Optional: local-only SSH override for testing against a non-LIACS server
# REMOTE_SSH_HOST = "example.ssh.host"
# REMOTE_SSH_USERNAME = "your-test-ssh-username"
# REMOTE_SSH_KEY = "-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"
# REMOTE_DATABASE_DIRECTORY = "/home/your-test-ssh-username/BS-Interviews/Database"

# Section for account names and passwords
[passwords]

# Test account (can attempt interview multiple times)
testaccount = "testpw"

# Add study accounts in the format:
# accountname = "password"
