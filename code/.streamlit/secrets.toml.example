# .streamlit/secrets.toml.example
#
# This is a template file. To use it:
# 1. Copy this file to secrets.toml in the same directory
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit secrets.toml to version control
#
# For Streamlit Cloud deployments, configure secrets through the
# Streamlit Cloud dashboard instead of using this file.

# Environment setting: "test" or "production"
ENV = "test"

# LLM provider and model
API_PROVIDER = "openai"  # openai | deepinfra | anthropic
MODEL = "gpt-4o-mini"

# Provider credentials
API_KEY = "your-openai-api-key-here"
# ANTHROPIC_API_KEY = "your-anthropic-api-key-here"
# DEEPINFRA_API_KEY = "your-deepinfra-api-key-here"

# Optional: TTS settings for speech output (DeepInfra)
TTS_MODEL = "hexgrad/Kokoro-82M"
TTS_VOICE = "af_heart"

# Optional: Email configuration
# USE_LIACS_EMAIL = false
# EMAIL_PASSWORD = "your-gmail-app-password-here"

# Optional: LIACS SSH configuration for remote email/database access
# LIACS_SSH_USERNAME = "your-liacs-username"
# LIACS_SSH_KEY = "-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"

# Section for account names and passwords
[passwords]

# Test account (can attempt interview multiple times)
testaccount = "testpw"

# Add study accounts in the format:
# accountname = "password"
